# ── Kalshi credentials ────────────────────────────────────────
KALSHI_EMAIL=your@email.com
KALSHI_PASSWORD=yourpassword
KALSHI_DEMO=true          # "true" = use demo account (safe for testing)

# ── Strategy tuning ───────────────────────────────────────────
MIN_EDGE=0.06             # minimum edge to trade (6%)
STRONG_EDGE=0.12          # single-bin trades require this edge (12%)
MIN_PROB=0.55             # minimum win probability to trade (55%)
MAX_SPREAD=5              # max trades per city per day

# ── Position sizing ───────────────────────────────────────────
KELLY_FRACTION=0.25       # fractional Kelly (0.25 = quarter-Kelly, conservative)
MAX_PCT_BANKROLL=0.05     # max 5% of bankroll on any single trade
MAX_TOTAL_DEPLOY=0.40     # max 40% of bankroll deployed at once
